Package: opencc
Architecture: any
Depends:
 ${shlibs:Depends},
 ${misc:Depends},
 libopencc1.4 (= ${binary:Version}),
 libopencc-data (>= ${source:Version}),
Description: Open Chinese Convert (OpenCC) command line tools
 OpenCC converts between Traditional Chinese, Simplified Chinese, and
 regional variants (Mainland/Hong Kong/Taiwan) and Japanese Shinjitai
 forms. This package provides the opencc command line converter, the
 opencc_dict dictionary format conversion tool, and the
 opencc_phrase_extract phrase extraction tool.

