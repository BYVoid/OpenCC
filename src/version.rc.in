#include <winver.h>

VS_VERSION_INFO VERSIONINFO
 FILEVERSION    @OPENCC_VERSION_MAJOR@,@OPENCC_VERSION_MINOR@,@OPENCC_VERSION_REVISION@,0
 PRODUCTVERSION @OPENCC_VERSION_MAJOR@,@OPENCC_VERSION_MINOR@,@OPENCC_VERSION_REVISION@,0
 FILEFLAGSMASK  VS_FFI_FILEFLAGSMASK
 FILEFLAGS      0x0L
 FILEOS         VOS_NT_WINDOWS32
 FILETYPE       @RC_FILE_TYPE@
 FILESUBTYPE    VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "OpenCC"
            VALUE "FileDescription",  "@RC_FILE_DESCRIPTION@"
            VALUE "FileVersion",      "@OPENCC_VERSION_MAJOR@.@OPENCC_VERSION_MINOR@.@OPENCC_VERSION_REVISION@"
            VALUE "InternalName",     "@RC_INTERNAL_NAME@"
            VALUE "LegalCopyright",   "Copyright 2010-2026 Carbo Kuo and contributors"
            VALUE "OriginalFilename", "@RC_ORIGINAL_FILENAME@"
            VALUE "ProductName",      "Open Chinese Convert (OpenCC)"
            VALUE "ProductVersion",   "@OPENCC_VERSION_MAJOR@.@OPENCC_VERSION_MINOR@.@OPENCC_VERSION_REVISION@"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
