filegroup(
    name = "config_test",
    srcs = [
        "config_test.json",
        "config_test_characters.txt",
        "config_test_phrases.txt",
    ],
    visibility = ["//visibility:public"],
)

filegroup(
    name = "config_test_with_policy",
    srcs = [
        "config_test_with_policy.json",
        "config_test_characters.txt",
        "config_test_phrases.txt",
    ],
    visibility = ["//visibility:public"],
)

# Schema validation for the with-policy variant; the original config_test.json
# is kept for backward-compatibility and is exercised by //src:config_test.
cc_test(
    name = "config_schema_validation_config_test_with_policy",
    size = "small",
    srcs = ["//data/config:config_schema_validation_test_src"],
    local_defines = [
        "BAZEL",
        "OPENCC_CONFIG_SCHEMA_TEST_FILE=\\\"test/config_test/config_test_with_policy.json\\\"",
    ],
    data = [
        ":config_test_with_policy",
        "//data/config:config_schema",
    ],
    deps = [
        "@bazel_tools//tools/cpp/runfiles",
        "@googletest//:gtest_main",
        "//deps/rapidjson-1.1.0:rapidjson",
    ],
)
